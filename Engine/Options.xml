    <Parameter>
        <RequestType>FreeNumber</RequestType>
        <Description>CascadeCount</Description>
        <Value>4</Value>
        <valueType>Long</valueType>
        <IsSet>True</IsSet>
        <Index>2</Index>
    </Parameter>
    <Parameter>
        <RequestType>FreeNumber</RequestType>
        <Description>CascadeLimitList</Description>
        <Value>5.0, 20.0, 50.0, 150.0, 250.0</Value>
        <valueType>FloatArray</valueType>
        <IsSet>True</IsSet>
        <Index>0</Index>
    </Parameter>
    <!-- Stagger updates:
     Cascade 1: updates at frames 1, 3, 5... (Interval 2, Offset 1)
     Cascade 2: updates at frames 2, 6, 10... (Interval 4, Offset 2)
     Cascade 3: updates at frames 4, 12, 20... (Interval 8, Offset 4)
     This ensures progressively less updates (frequency 1/2^i)
     and distributes the load so we don't have spikes where all update at once.
     increasing these values would improve framerate, but will delay shadows-->
    <Parameter>
        <RequestType>FreeNumber</RequestType>
        <Description>CascadeStaggerOffsets</Description>
        <!-- This variable sets the which frame will render which cascade. Cascade 0 updates every frame, so skipped.-->
        <Value>4, 1, 2, 4</Value>
<!--        <Value>4, 0, 0, 0</Value> no offset, for rendering each frame-->
        <valueType>LongArray</valueType>
        <IsSet>True</IsSet>
        <Index>0</Index>
    </Parameter>
    <Parameter>
        <RequestType>FreeNumber</RequestType>
        <Description>CascadeStaggerIntervals</Description>
        <!-- This variable sets the how often we render the cascade. Cascade 0 updates every frame, so skipped. -->
        <Value>4, 2, 4, 8</Value>
<!--        <Value>4, 1, 1, 1</Value> interval 1 is each frame, enable with offset for all cascades each frame-->
        <valueType>LongArray</valueType>
        <IsSet>True</IsSet>
        <Index>0</Index>
    </Parameter>
    <Parameter>
        <RequestType>FreeNumber</RequestType>
        <Description>LodDistanceList</Description>
        <!-- This variable sets the LOD distances, so 10 is the second lod, 25 is third, etc. we build 3 LODs for 1 model, so 4 levels -->
        <Value>5, 10, 25, 150, 250</Value>
        <valueType>LongArray</valueType>
        <IsSet>True</IsSet>
        <Index>0</Index>
    </Parameter>
    <Parameter>
        <RequestType>FreeNumber</RequestType>
        <Description>SkipRenderDistance</Description>
        <!--This variable sets what is the distance to start skipping render for an object. To skip Render size also needs to be set-->
        <Value>50.0</Value>
        <valueType>Double</valueType>
        <IsSet>True</IsSet>
        <Index>0</Index>
    </Parameter>
    <Parameter>
        <RequestType>FreeNumber</RequestType>
        <Description>SkipRenderSize</Description>
        <!-- This variable sets what is the size on screen engine can start skipping. It is a percentage, and only applies to models that are more distant than Skip Render Distance -->
        <Value>0.075</Value>
        <valueType>Double</valueType>
        <IsSet>True</IsSet>
        <Index>0</Index>
    </Parameter>
    <Parameter>
        <RequestType>FreeNumber</RequestType>
        <Description>MaxSkipRenderSize</Description>
        <!-- This variable sets what is the size of objects can't be skipped. This is required because objects like ground/wall skipping can be visually jarring-->
        <Value>3</Value>
        <valueType>Double</valueType>
        <IsSet>True</IsSet>
        <Index>0</Index>
    </Parameter>
    <Parameter>
        <RequestType>FreeNumber</RequestType>
        <Description>SplitModelToMeshCount</Description>
        <!-- When doing occlusion tests, we prefer to do it per model. If a model contains more than this number of meshes, only then the tests will be done per mesh-->
        <Value>10</Value>
        <valueType>Long</valueType>
        <IsSet>True</IsSet>
        <Index>0</Index>
    </Parameter>
    <Parameter>
        <RequestType>FreeNumber</RequestType>
        <Description>SoftwareOcclusionRenderWidth</Description>
        <!--This option sets the software rasterized depth buffers width, needs to be a factor of 8-->
        <Value>512</Value>
        <valueType>Long</valueType>
        <IsSet>True</IsSet>
        <Index>0</Index>
    </Parameter>
    <Parameter>
        <RequestType>FreeNumber</RequestType>
        <Description>SoftwareOcclusionRenderHeight</Description>
        <!--This option sets the software rasterized depth buffers height, needs to be a factor of 8-->
        <Value>256</Value>
        <valueType>Long</valueType>
        <IsSet>True</IsSet>
        <Index>0</Index>
    </Parameter>
    <Parameter>
        <RequestType>FreeText</RequestType>
        <Description>SoftwareOcclusionRenderDump</Description>
        <!--This option enables dumping the software rasterized depth buffer to a ppm file. For debug purposes only.-->
        <Value>False</Value>
        <valueType>Boolean</valueType>
        <IsSet>True</IsSet>
        <Index>0</Index>
    </Parameter>
    <Parameter>
        <RequestType>FreeNumber</RequestType>
        <Description>SoftwareOcclusionRenderDumpFrequency</Description>
        <!--This option sets frequency of dumping the software rasterized depth buffer to a ppm file. For debug purposes only.-->
        <Value>300</Value>
        <valueType>Long</valueType>
        <IsSet>True</IsSet>
        <Index>0</Index>
    </Parameter>
    <Parameter>
        <RequestType>FreeNumber</RequestType>
        <Description>SoftwareOcclusionOccluderSize</Description>
        <!--This option sets the size limit for objects to be considered occluder. It is on screen size, 1 is full coverage, 0 is no coverage-->
        <Value>0.5</Value>
        <valueType>Double</valueType>
        <IsSet>True</IsSet>
        <Index>0</Index>
    </Parameter>
    <Parameter>
        <RequestType>FreeText</RequestType>
        <Description>GraphicsBackend</Description>
        <Value>libOpenGLGraphicsBackend</Value>
        <valueType>String</valueType>
        <IsSet>True</IsSet>
        <Index>0</Index>
    </Parameter>
</Options>